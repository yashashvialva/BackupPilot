# ==============================================================================
# Database
# ==============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backuppilot?schema=public"

# ==============================================================================
# AWS
# ==============================================================================
MOCK_AWS="true"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="mock_access_key_id"
AWS_SECRET_ACCESS_KEY="mock_secret_access_key"

# ==============================================================================
# Authentication
# ==============================================================================
COGNITO_USER_POOL_ID="us-east-1_mockpoolid"
COGNITO_CLIENT_ID="mockclientid12345"

# ==============================================================================
# Internal
# ==============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==============================================================================
# Lambda
# ==============================================================================
BACKUP_WORKER_LAMBDA_ARN="arn:aws:lambda:us-east-1:123456789012:function:backuppilot-backup-worker"
RESTORE_WORKER_LAMBDA_ARN="arn:aws:lambda:us-east-1:123456789012:function:backuppilot-restore-worker"

# ==============================================================================
# EventBridge
# ==============================================================================
EVENTBRIDGE_SCHEDULER_ROLE_ARN="arn:aws:iam::123456789012:role/backuppilot-scheduler-role"

# ==============================================================================
# SNS
# ==============================================================================
SNS_TOPIC_ARN="arn:aws:sns:us-east-1:123456789012:backuppilot-alerts"
